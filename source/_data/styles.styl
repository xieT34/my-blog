@import url("https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css");


body {
  background-image: url("https://img.aris10xie34.top/images/137504120_p0.png");
  background-size: cover;
  background-attachment: fixed;
  background-repeat: no-repeat;
  background-position: center center;
}


.main-inner {
  background: rgba(255, 255, 255, 0.85) !important;
  border-radius: 8px;
  padding: 20px;
}


.sidebar-inner {
  background: rgba(255, 255, 255, 0.85) !important;
  border-radius: 8px;
}


// 链接颜色
a {
  color: #2d8cf0;
  &:hover {
    color: darken(#2d8cf0, 10%);
  }
}

.post-title {
  a {
    color: #1a1a2e;  // 深色标题
    &:hover {
      color: #1a1a2e;
    }
  }
}